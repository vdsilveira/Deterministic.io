{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "command": "npx",
      "args": ["-y", "ctx7", "mcp"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}